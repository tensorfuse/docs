{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Whip Help Center",
  "description": "The official Whip help center. Learn how to build, remix, publish, and share mini apps with AI on Whip — no code needed. Guides, FAQs, and what's new.",
  "colors": {
    "primary": "#C60009",
    "light": "#FF565E",
    "dark": "#C60009"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "light": "#F7F7F7",
      "dark": "#0A0A0A"
    }
  },
  "fonts": {
    "heading": {
      "family": "Satoshi",
      "weight": 700,
      "source": "https://cdn.fontshare.com/wf/LAFFD4SDUCDVQEXFPDC7C53EQ4ZELWQI/PXCT3G6LO6ICM5I3NTYENYPWJAECAWDD/GHM6WVH6MILNYOOCXHXB5GTSGNTMGXZR.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Satoshi",
      "weight": 400,
      "source": "https://cdn.fontshare.com/wf/TTX2Z3BF3P6Y5BQT3IV2VNOK6FL22KUT/7QYRJOI3JIMYHGY6CH7SOIFRQLZOLNJ6/KFIAZD4RUMEZIYV6FQ3T3GP5PDBDB6JY.woff2",
      "format": "woff2"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "getting-started/download-and-sign-in",
              "getting-started/set-up-your-profile",
              "getting-started/create-your-first-app"
            ]
          },
          {
            "group": "Building apps",
            "pages": [
              "building/how-whip-builds-your-app",
              "building/prompt-tips-and-ideas",
              "building/edit-your-app",
              "building/versions-and-history",
              "building/attachments",
              "building/what-apps-can-do",
              "building/apis-and-libraries",
              "building/build-limits-and-failed-builds"
            ]
          },
          {
            "group": "Publishing & sharing",
            "pages": [
              "sharing/publish-your-app",
              "sharing/highlight-reels",
              "sharing/share-links",
              "sharing/unpublish-and-archive"
            ]
          },
          {
            "group": "Discovering apps",
            "pages": [
              "discover/the-feed",
              "discover/search",
              "discover/remix-apps"
            ]
          },
          {
            "group": "Profiles & social",
            "pages": [
              "social/profiles",
              "social/follow-like-save",
              "social/comments",
              "social/notifications"
            ]
          },
          {
            "group": "Using apps",
            "pages": [
              "using/open-and-use-apps",
              "using/home-screen-and-folders",
              "using/leaderboards",
              "using/app-permissions",
              "using/data-ai-and-consent"
            ]
          },
          {
            "group": "Account & safety",
            "pages": [
              "account/manage-your-account",
              "account/age-requirements",
              "account/privacy-and-data",
              "account/block-users",
              "account/report-content",
              "account/delete-your-account"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "help/troubleshooting",
              "help/contact"
            ]
          }
        ]
      },
      {
        "tab": "FAQ",
        "groups": [
          {
            "group": "Frequently asked questions",
            "pages": [
              "faq/general",
              "faq/creating-apps",
              "faq/privacy-and-safety"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "whip.run",
          "href": "https://whip.run",
          "icon": "globe"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.com/invite/bsSeNMQkTZ",
          "icon": "/icons/discord.svg"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://whip.run"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "icon": "/icons/discord.svg",
        "href": "https://discord.com/invite/bsSeNMQkTZ"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get the app",
      "href": "https://whip.run"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "redirects": [
    {
      "source": "/using/play-together",
      "destination": "/using/leaderboards"
    }
  ],
  "metadata": {
    "timestamp": true
  },
  "thumbnails": {
    "background": "/images/og-background.png"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "Whip Help Center",
      "og:type": "website",
      "twitter:card": "summary_large_image",
      "twitter:site": "@joinwhip"
    }
  },
  "search": {
    "prompt": "Search Whip help…"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/joinwhip",
      "instagram": "https://www.instagram.com/makewhips",
      "discord": "https://discord.com/invite/bsSeNMQkTZ",
      "youtube": "https://www.youtube.com/@joinwhip"
    },
    "links": [
      {
        "header": "Whip",
        "items": [
          {
            "label": "Get the app",
            "href": "https://whip.run"
          },
          {
            "label": "TikTok",
            "href": "https://www.tiktok.com/@joinwhip"
          }
        ]
      },
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms of Service",
            "href": "https://whip.run/terms"
          },
          {
            "label": "Privacy Policy",
            "href": "https://whip.run/privacy"
          }
        ]
      }
    ]
  }
}
